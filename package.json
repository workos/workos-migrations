{
  "name": "workos-migrations",
  "version": "1.0.0",
  "description": "CLI tool to migrate data from various identity providers to WorkOS",
  "main": "dist/index.js",
  "bin": {
    "workos-migrations": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.md\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.md\" \"*.json\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "workos",
    "migration",
    "cli",
    "auth0",
    "clerk",
    "firebase",
    "cognito"
  ],
  "author": "WorkOS",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.15.0",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "csv-parse": "^6.2.1",
    "form-data": "^4.0.4",
    "inquirer": "^13.4.2"
  },
  "devDependencies": {
    "@types/form-data": "^2.2.1",
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/workos/workos-migrations.git"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
